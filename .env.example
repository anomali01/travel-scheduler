# ============================================================
# TravelAI Indonesia — Konfigurasi API Keys
# ============================================================
# Salin file ini menjadi .env dan isi dengan API key kamu.
# File .env TIDAK boleh di-commit ke Git!
#
# Semua field OPSIONAL — aplikasi tetap berjalan tanpa API key
# menggunakan data estimasi lokal.
# ============================================================

# ── GOOGLE GEMINI AI ──────────────────────────────────────────
# Digunakan untuk: NLP Parser (parse input natural language)
# Daftar gratis: https://aistudio.google.com/app/apikey
# Quota gratis: 15 req/menit, 1500 req/hari (Gemini 1.5 Flash)
GEMINI_API_KEY=your_gemini_api_key_here

# ── AMADEUS FLIGHT API ────────────────────────────────────────
# Digunakan untuk: Data penerbangan real dari 400+ maskapai
# Daftar gratis (sandbox): https://developers.amadeus.com
# Sandbox: GRATIS, data test (bukan live), tidak perlu kartu kredit
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here

# ── GOOGLE MAPS / PLACES API ──────────────────────────────────
# Digunakan untuk: Data hotel dengan foto & review nyata
# Daftar: https://console.cloud.google.com
# Note: Ada biaya setelah free tier habis (~$200/bulan gratis)
# Enable: Places API, Maps JavaScript API
GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# ── CATATAN ───────────────────────────────────────────────────
# Open-Meteo (cuaca)   : GRATIS, tidak perlu API key
# OpenStreetMap/Overpass: GRATIS, tidak perlu API key
# Nominatim geocoding  : GRATIS, tidak perlu API key
# ─────────────────────────────────────────────────────────────
